// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
}

model User {
  id                  Int               @id  @default(autoincrement())
  firebaseUid         String            @unique @db.VarChar(128)
  firstName           String            @db.VarChar(150)
  lastName            String?           @db.VarChar(150)
  email               String            @unique @db.VarChar(320)
  phone               String?           @db.VarChar(15)
  photoUrl            String?           @db.VarChar(2048)
  role                Role              @default(GUEST)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  verifiedDriver       Boolean           @default(false)
  rating              Int               @default(0)
  tripsCompleted      Int               @default(0)
  stripeAccountId     String?           @db.VarChar(100)
  isActive            Boolean           @default(true)

  addresses           Address[]
  driverLicenses      DriverLicense[]
  languages           Language[]
  vehicles            Vehicle[]
  trips               Trip[]
  bookings            Booking[]
  invoices            Invoice[]

  @@index([role])
  @@index([createdAt])
}

enum Role {
  GUEST
  HOST
  ADMIN
}

model DriverLicense {
  id                  Int               @id @default(autoincrement())
  licenseNumber       String            @unique @db.VarChar(100)
  issuingState        String            @db.VarChar(100)
  expirationDate      String            @db.VarChar(15)
  frontImage          String            @db.VarChar(2048)
  backImage           String            @db.VarChar(2048)
  isVerified           Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  userId              Int?              
  user                User?              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([issuingState])
  @@index([isVerified])
}

model Address {
  id                  Int               @id @default(autoincrement())
  street              String            @db.VarChar(255)
  apartment           String?           @db.VarChar(50)
  city                String            @db.VarChar(50)
  state               String            @db.VarChar(30)
  zip                 Int               @db.Integer
  country             String            @db.VarChar(100)
  placeId             String?           @unique @db.VarChar(100)
  latitude            Float?             @default(0.0)
  longitude           Float?             @default(0.0)
  isActive            Boolean           @default(true)

  userId              Int?               
  user                User?              @relation(fields: [userId], references: [id])

  vehicleId           Int?
  vehicle             Vehicle?          @relation(fields: [vehicleId], references: [id])

  @@index([userId])
  @@index([city, state])
  @@index([latitude, longitude])
}

model Language {
  id                  Int               @id @default(autoincrement())
  name                String            @db.VarChar(100)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  userId              Int
  user                User              @relation(fields: [userId], references: [id])
}

model Vehicle {
  id                  Int               @id @default(autoincrement())
  make                String
  model               String
  year                Int
  licensePlate        String
  color               String
  seats               Int               @default(5)
  type                String
  vehicleImage        String?
  verified             Boolean           @default(false)
  rating              Float             @default(0)
  hasSeatbelts        Boolean           @default(true)
  seatbeltType        SeatbeltType      @default(BOTH)
  condition           Condition         @default(GOOD)
  value               Int
  vin                 String
  mileage             Int
  transmission        Transmission      @default(AUTOMATIC)
  salesTaxPaid        Boolean
  trim                String
  bodyStyle           String
  hasSalvageTitle     Boolean
  extraInfo           String

  userId              Int
  user                User              @relation(fields: [userId], references: [id])

  trips               Trip[]

  addresses           Address[]

  @@index([userId])
  @@index([make, model])
  @@index([licensePlate])
}

enum SeatbeltType {
  SHOULDER
  LAP
  BOTH
}

enum Condition {
  EXCELLENT
  GOOD
  FAIR
  NOT_WORKING
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

model Trip {
  id                  Int               @id @default(autoincrement())
  startLocation       String
  endLocation         String
  startAt             DateTime          
  endAt               DateTime          
  status              Status            @default(SCHEDULED)
  price               Float
  discount            Float             @default(0)
  rating              Float             @default(0)

  userId              Int
  user                User              @relation(fields: [userId], references: [id])
  vehicleId           Int
  vehicle             Vehicle           @relation(fields: [vehicleId], references: [id])
  bookings            Booking?
  invoices            Invoice[]

  @@index([userId])
  @@index([vehicleId])
  @@index([status])
  @@index([startAt, endAt])
}

enum Status {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELED
}

model Booking {
  id                  Int               @id @default(autoincrement())
  bookedAt            DateTime          @default(now())
  stripeId            String?
  status              BookingStatus     @default(PENDING)

  userId              Int
  user                User              @relation(fields: [userId], references: [id])
  tripId              Int?              @unique
  trip                Trip?             @relation(fields: [tripId], references: [id])

  @@index([userId])
  @@index([tripId])
  @@index([status])
  @@index([bookedAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

model Invoice {
  id                Int                @id @default(autoincrement())
  basePrice         Float
  discount          Float              @default(0)
  extrasTotal       Float              @default(0)
  tax               Float
  feesTotal         Float
  milageFee         Float
  lateFee           Float              @default(0)
  totalPrice        Float

  userId            Int
  user              User               @relation(fields: [userId], references: [id])
  tripId            Int
  trip              Trip               @relation(fields: [tripId], references: [id])

  @@index([userId])
  @@index([tripId])
}