// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
}

model User {
  id              Int      @id  @default(autoincrement())
  firebaseUid     String   @unique @db.VarChar(128)
  firstName       String   @db.VarChar(150)
  lastName        String?   @db.VarChar(150)
  email           String   @unique @db.VarChar(150)
  phone           String?  @db.VarChar(14)
  photoUrl        String?  @db.VarChar(2048)
  role            Role     @default(GUEST)
  driverLicense   DriverLicense?
  address         Address?
  language        Language?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  verifiedDriver  Boolean  @default(false)
  rating          Int?     @default(0)
  tripsCompleted  Int?     @default(0)
  stripeAccountId String?  @db.VarChar(100)
}

enum Role {
  GUEST
  HOST
  ADMIN
}

model DriverLicense {
  id          Int      @id @default(autoincrement())
  number      String   @unique @db.VarChar(100)
  state       String   @db.VarChar(100)
  expiration  DateTime
  frontImage  String   @db.VarChar(2048)
  backImage   String   @db.VarChar(2048)
  verified    Boolean  @default(false)
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
}

model Address {
  id          Int      @id @default(autoincrement())
  street      String   @db.VarChar(255)
  apartment   String?  @db.VarChar(50)
  city        String   @db.VarChar(50)
  state       String   @db.VarChar(30)
  zip         Int      @db.Integer
  country     String   @db.VarChar(100)
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
}

model Language {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
}
